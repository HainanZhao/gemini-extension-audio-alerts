{
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "notify-audio",
            "type": "command",
            "command": "${extensionPath}/hooks/handle_notification.sh --notification"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "record-start",
            "type": "command",
            "command": "${extensionPath}/hooks/handle_notification.sh --before"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "notify-done",
            "type": "command",
            "command": "${extensionPath}/hooks/handle_notification.sh --finished"
          }
        ]
      }
    ]
  }
}
