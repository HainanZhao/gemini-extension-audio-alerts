{
  "name": "audio-alerts",
  "version": "1.2.0",
  "description": "Custom audio alerts for Gemini CLI (macOS/Linux), handling Tool Permissions, Errors, and Task Completion with themed sound packs (retro, portal, default, hero, premium).",
  "hooks": "hooks/hooks.json",
  "settings": [
    {
      "name": "Audio Alert Theme",
      "description": "Select the audio theme (default[default], retro, portal, hero, premium).",
      "envVar": "AUDIO_ALERTS_THEME",
      "type": "choice",
      "default": "default",
      "options": [
        {
          "value": "default",
          "label": "Default (Agent Thriller)"
        },
        {
          "value": "retro",
          "label": "Retro (8-bit)"
        },
        {
          "value": "portal",
          "label": "Portal (Sci-fi)"
        },
        {
          "value": "hero",
          "label": "Hero (Cinematic)"
        },
        {
          "value": "premium",
          "label": "Premium (Elegant)"
        }
      ],
      "sensitive": false
    },
    {
      "name": "Audio Alert Disable Text-to-Speech",
      "description": "Disable the voice prompts (false[default], true).",
      "envVar": "AUDIO_ALERTS_DISABLE_TTS",
      "type": "boolean",
      "default": false,
      "sensitive": false
    }
  ]
}
